<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!--


@author Harvey Duran
@since TBD
-->
<VBox alignment="TOP_CENTER" spacing="15.0"
  xmlns="http://javafx.com/javafx/21"
  xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="com.gradetracker.controller.StudentClassController">

  <padding>
    <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
  </padding>

  <Label fx:id="classTitleLabel" text="Class Name" />
  <Label fx:id="classDescriptionLabel" text="Class description goes here" />

  <HBox spacing="10.0">
    <Button text="Back" onAction="#handleBack" />
    <Button text="Logout" onAction="#handleLogout" />
  </HBox>

  <TableView fx:id="assignmentTable" prefWidth="600.0">
    <columns>
      <TableColumn fx:id="titleColumn" text="Assignment Title" prefWidth="200.0" />
      <TableColumn fx:id="dueDateColumn" text="Due Date" prefWidth="150.0" />
      <TableColumn fx:id="scoreColumn" text="Score" prefWidth="100.0" />
      <TableColumn fx:id="maxGradeColumn" text="Max Grade" prefWidth="100.0" />
    </columns>
  </TableView>

</VBox>