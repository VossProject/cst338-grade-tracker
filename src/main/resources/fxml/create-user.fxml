<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<!--


@author Robert Mozzetti
@since 04/13/26
-->
<VBox alignment="TOP_CENTER" spacing="15.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.gradetracker.controller.CreateUserController">

    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>

    <Label text="Create User"
           style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <TextField fx:id="usernameField" promptText="Username" />
    <TextField fx:id="firstNameField" promptText="First Name" />
    <TextField fx:id="lastNameField" promptText="Last Name" />
    <ComboBox fx:id="roleComboBox" promptText="Select Role" maxWidth="Infinity" />
    <PasswordField fx:id="passwordField" promptText="Password" />
    <PasswordField fx:id="confirmPasswordField" promptText="Confirm Password" />

    <HBox spacing="10.0" alignment="CENTER">
        <Button text="Back" onAction="#handleBack" />
        <Button text="Create User" onAction="#handleCreateUser" styleClass="success" />
    </HBox>

    <Label fx:id="messageLabel" text="" style="-fx-text-fill: red;" />
</VBox>
