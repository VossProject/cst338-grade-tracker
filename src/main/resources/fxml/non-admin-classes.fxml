<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.gradetracker.controller.NonAdminClassesController"
            prefHeight="400.0" prefWidth="600.0">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15.0" prefHeight="50.0"
              style="-fx-background-color: -color-bg-inset;">
            <Label text="Classes" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS" />
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <FlowPane hgap="20.0" vgap="20.0" style="-fx-padding: 20;" fx:id="cardList">
            </FlowPane>
        </ScrollPane>
    </center>
</BorderPane>
