<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<!--
Login view layout for the Grade Tracker application.

@author Harvey Duran
@since 04/24/26
-->
<VBox alignment="CENTER" spacing="15.0"
  xmlns="http://javafx.com/javafx/21"
  xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="com.gradetracker.controller.LoginController">

  <padding>
    <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
  </padding>

  <Label text="Grade Tracker"
    style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

  <TextField fx:id="usernameField" promptText="Username" maxWidth="300.0" />

  <PasswordField fx:id="passwordField" promptText="Password" maxWidth="300.0" />

  <Button text="Login" onAction="#handleLogin" defaultButton="true"
    style="-fx-background-color: #76D86D; -fx-text-fill: black;"/>

  <Label fx:id="messageLabel" text=""
    style="-fx-text-fill: #FF9580;"/>

</VBox>
