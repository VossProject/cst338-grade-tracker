<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane  xmlns="http://javafx.com/javafx"
             xmlns:fx="http://javafx.com/fxml"
             fx:controller="com.gradetracker.controller.UserListController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15.0" prefHeight="50.0"
              style="-fx-background-color: -color-bg-inset;">
            <Label text="Users" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Create User" styleClass="accent, borderless, rounded" maxWidth="Infinity" onAction="#createUser" style="-fx-font-weight: bold; -fx-text-fill: white;"></Button>
        </HBox>
    </top>
    <center>
        <TableView fx:id="userTable">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="userIdColumn" text="ID #" prefWidth="100.0" minWidth="100.0" maxWidth="100.0"/>
                <TableColumn fx:id="userNameColumn" text="Username"/>
                <TableColumn fx:id="roleColumn" text="Role"/>
            </columns>
        </TableView>
    </center>
</BorderPane>
