<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<!--

@author Robert Mozzetti
@since 04/17/26
-->
<VBox alignment="TOP_CENTER" spacing="15.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.gradetracker.controller.CreateClassController">

    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>

    <Label text="Create Class"
           style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <TextField fx:id="classNameField" promptText="Class Name" />

    <TextArea fx:id="descriptionField"
              promptText="Class Description"
              prefRowCount="3" />

    <ComboBox fx:id="teacherComboBox"
              promptText="Assign Teacher"
              maxWidth="Infinity" />

    <HBox spacing="10.0" alignment="CENTER">
        <ComboBox fx:id="studentComboBox"
                  promptText="Select Student to Enroll"
                  maxWidth="Infinity"
                  HBox.hgrow="ALWAYS" />
        <Button text="Add Student" onAction="#handleAddStudent" />
    </HBox>

    <Label text="Enrolled Students" style="-fx-font-weight: bold;" />
    <ListView fx:id="enrolledStudentsListView" prefHeight="160.0" />

    <HBox spacing="10.0" alignment="CENTER">
        <Button fx:id="submitButton" text="Submit" onAction="#handleSubmit" styleClass="success" />
    </HBox>

    <Label fx:id="messageLabel" text="" />
</VBox>
